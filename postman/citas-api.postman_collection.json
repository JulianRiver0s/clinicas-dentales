    {
      "name": "Citas",
      "item": [
        {
          "name": "Agendar cita",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documento\": \"1234567890\",\n  \"nombrePaciente\": \"María Rodríguez\",\n  \"consultorioId\": 1,\n  \"odontologoId\": 1,\n  \"procedimientoId\": 1,\n  \"fechaHora\": \"2026-07-15T14:30:00Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/citas",
              "host": ["{{base_url}}"],
              "path": ["citas"]
            },
            "description": "ADMIN o RECEPCIONISTA. fechaHora debe ser futura (ISO-8601 UTC). documento: 6-12 dígitos. Devuelve { id }."
          }
        },
        {
          "name": "Check-in de cita",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id/checkin",
              "host": ["{{base_url}}"],
              "path": ["citas", ":id", "checkin"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Sin cuerpo."
          }
        },
        {
          "name": "Registrar atención",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documento\": \"1234567890\",\n  \"citaId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/citas/registrar-atencion",
              "host": ["{{base_url}}"],
              "path": ["citas", "registrar-atencion"]
            },
            "description": "ADMIN o RECEPCIONISTA. Cierra la atención de la cita. Devuelve { mensaje, totalCobrado }."
          }
        },
        {
          "name": "Cancelar cita",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id/cancelar",
              "host": ["{{base_url}}"],
