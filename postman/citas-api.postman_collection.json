          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/clinicas/:id",
              "host": ["{{base_url}}"],
              "path": ["clinicas", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Solo ADMIN."
          }
        },
        {
          "name": "Crear clínica",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Clínica Central\",\n  \"direccion\": \"Calle 123\",\n  \"ciudad\": \"Bogotá\",\n  \"telefono\": \"+57 1 2345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/clinicas",
              "host": ["{{base_url}}"],
              "path": ["clinicas"]
            },
            "description": "Solo ADMIN. nombre es obligatorio."
          }
        },
        {
          "name": "Actualizar clínica",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Clínica Central\",\n  \"direccion\": \"Calle 123\",\n  \"ciudad\": \"Bogotá\",\n  \"telefono\": \"+57 1 2345678\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/clinicas/:id",
              "host": ["{{base_url}}"],
              "path": ["clinicas", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Solo ADMIN."
          }
        },
        {
          "name": "Eliminar clínica",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/clinicas/:id",
              "host": ["{{base_url}}"],
              "path": ["clinicas", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Solo ADMIN. Responde 204 sin cuerpo."
          }
        },
        {
          "name": "Asociar recepcionista a clínica",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/clinicas/:id/recepcionistas?usuarioId=2",
              "host": ["{{base_url}}"],
              "path": ["clinicas", ":id", "recepcionistas"],
              "query": [{ "key": "usuarioId", "value": "2" }],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "Solo ADMIN. usuarioId = id del usuario RECEPCIONISTA (demo: 2)."
          }
        }
      ]
    },
