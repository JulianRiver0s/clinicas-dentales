    {
      "name": "Citas",
      "item": [
        {
          "name": "Agendar cita",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documento\": \"1234567890\",\n  \"nombrePaciente\": \"María Rodríguez\",\n  \"consultorioId\": 1,\n  \"odontologoId\": 1,\n  \"procedimientoId\": 1,\n  \"fechaHora\": \"2026-07-15T14:30:00Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/citas",
              "host": ["{{base_url}}"],
              "path": ["citas"]
            },
            "description": "ADMIN o RECEPCIONISTA. fechaHora debe ser futura (ISO-8601 UTC). documento: 6-12 dígitos. Devuelve { id }."
          }
        },
        {
          "name": "Check-in de cita",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id/checkin",
              "host": ["{{base_url}}"],
              "path": ["citas", ":id", "checkin"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Sin cuerpo."
          }
        },
        {
          "name": "Registrar atención",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"documento\": \"1234567890\",\n  \"citaId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/citas/registrar-atencion",
              "host": ["{{base_url}}"],
              "path": ["citas", "registrar-atencion"]
            },
            "description": "ADMIN o RECEPCIONISTA. Cierra la atención de la cita. Devuelve { mensaje, totalCobrado }."
          }
        },
        {
          "name": "Cancelar cita",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id/cancelar",
              "host": ["{{base_url}}"],
              "path": ["citas", ":id", "cancelar"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Cancela la cita. Sin cuerpo. Devuelve { mensaje }."
          }
        },
        {
          "name": "Marcar inasistencia",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id/no-show",
              "host": ["{{base_url}}"],
              "path": ["citas", ":id", "no-show"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Marca la cita como inasistencia. Sin cuerpo. Devuelve { mensaje }."
          }
        },
        {
          "name": "Listado del día",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/dia?clinicaId=1&fecha=2026-06-27",
              "host": ["{{base_url}}"],
              "path": ["citas", "dia"],
              "query": [
                { "key": "clinicaId", "value": "1" },
                { "key": "consultorioId", "value": "1", "disabled": true },
                { "key": "fecha", "value": "2026-06-27", "description": "Opcional (YYYY-MM-DD); por defecto hoy." }
              ]
            },
            "description": "ADMIN o RECEPCIONISTA. Citas de un día por clínica y/o consultorio (debe indicar al menos uno). Shape §4.5: id, documentoPaciente, nombrePaciente, odontologo, procedimiento, fechaHora, estado. El RECEPCIONISTA solo ve sus clínicas."
          }
        },
        {
          "name": "Listar citas (agendadas y atendidas)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas?estado=ATENDIDA&clinicaId=1",
              "host": ["{{base_url}}"],
              "path": ["citas"],
              "query": [
                { "key": "estado", "value": "ATENDIDA", "description": "Opcional: AGENDADA, EN_CURSO, ATENDIDA, CANCELADA, INASISTENCIA." },
                { "key": "clinicaId", "value": "1", "description": "Opcional." },
                { "key": "fecha", "value": "2026-06-27", "description": "Opcional (YYYY-MM-DD).", "disabled": true }
              ]
            },
            "description": "ADMIN o RECEPCIONISTA. Listado con filtros opcionales (todos combinables). El RECEPCIONISTA queda acotado a sus clínicas."
          }
        },
        {
          "name": "Buscar por documento (parcial)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/buscar?documento=10",
              "host": ["{{base_url}}"],
              "path": ["citas", "buscar"],
              "query": [{ "key": "documento", "value": "10" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Coincidencia parcial (LIKE %doc%) sobre el documento del paciente."
          }
        },
        {
          "name": "Detalle de cita",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/citas/:id",
              "host": ["{{base_url}}"],
              "path": ["citas", ":id"],
              "variable": [{ "key": "id", "value": "1" }]
            },
            "description": "ADMIN o RECEPCIONISTA. Detalle con sede, costo y tiempos reales. El RECEPCIONISTA recibe 403 si la cita es de una clínica ajena."
          }
        }
      ]
    },
